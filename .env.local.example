# 複製這個檔案為 .env.local，填入你自己的值

# Supabase 專案設定（在 Supabase 後台 → Project Settings → API 取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 前台模式：MAIN（一般前台，需登入/LINE/Discord）或 FB（免登入、FB 前台）
FRONTEND_MODE=MAIN

# 後台密碼（進入 /admin 頁面用）
ADMIN_PW=請改成你自己的密碼

# 密碼雜湊固定鹽（自己改一組即可，改了之後舊密碼會失效）
PW_SALT=mibu_pw_v1

# Discord Webhook（選填，下單通知用；沒有就留空）
DISCORD_WEBHOOK_URL=
