# 複製這個檔案為 .env.local，填入你自己的值

# Supabase 專案設定（在 Supabase 後台 → Project Settings → API 取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 後台管理者相關
# 兩組邀請碼分別對應不同權限，你要給誰哪個等級，就給他對應的邀請碼
# OWNER：最高權限，能看到/操作會員相關工具（合併會員、重設密碼）
# STAFF：一般管理者，只能管理分類/企劃/商品，看不到會員相關工具
ADMIN_INVITE_CODE_OWNER=請改成一組只有你自己知道的邀請碼
ADMIN_INVITE_CODE_STAFF=請改成另一組給一般管理者用的邀請碼

# Session 簽章密鑰：隨便打一串長長的亂數字串即可，不要外流（外流的話有心人可以偽造登入通行證）
ADMIN_TOKEN_SECRET=請改成一串至少32字的隨機亂碼

# Discord Webhook（選填，下單通知用；沒有就留空）
DISCORD_WEBHOOK_URL=

# 寄信服務（用你自己的 Gmail 帳號透過 SMTP 寄信，不需要網域也能寄給任何人）
# 1. 到你的 Gmail 帳號開啟兩步驟驗證
# 2. 到 myaccount.google.com/apppasswords 產生一組應用程式專用密碼（16 碼）
GMAIL_USER=你的Gmail帳號@gmail.com
GMAIL_APP_PASSWORD=你產生的16碼應用程式密碼
EMAIL_FROM=米舖 <你的Gmail帳號@gmail.com>

# 你的網站正式網址（寄信裡的連結會用到），例如 https://mibu-app.vercel.app
# 本機測試不用填，會自動用 http://localhost:3000
NEXT_PUBLIC_SITE_URL=
